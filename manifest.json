{
  "manifest_version": 3,
  "name": "StyleSnoop",
  "version": "1.0.0",
  "description": "Snoop on element styles without DOM injection. A clean, premium CSS inspector.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon 16x16.png",
      "32": "icons/icon 32x32.png",
      "64": "icons/icon 64x64.png",
      "128": "icons/icon 128x128.png"
    }
  },
  "icons": {
    "16": "icons/icon 16x16.png",
    "32": "icons/icon 32x32.png",
    "64": "icons/icon 64x64.png",
    "128": "icons/icon 128x128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "history.html", "history.css", "history.js", "fonts/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "Toggle StyleSnoop Inspector"
    }
  }
}
